// ast.ly:355
class Block {
  span: Span
}

// ast.ly:102
class ClassDecl {
  implements: [Sym]
  is_permanent: bool
  is_public: bool
  name: Sym?
  span: Span
}

// ast.ly:234
class Comment {
  pos: Pos
  text: string
}

// ast.ly:226
class ConstDecl {
  is_public: bool
  name: Sym?
  span: Span
  type_expr: TypeExpr?
  value: Expr?
}

// ast.ly:151
class DestructorBlock {
  body: Block?
  span: Span
  type_param: Sym?
}

// ast.ly:341
class ElseIf {
  body: Block?
  condition: Expr?
  span: Span
}

// ast.ly:128
class EnumDecl {
  is_public: bool
  name: Sym?
  span: Span
}

// ast.ly:122
class EnumVariant {
  name: Sym?
  span: Span
}

// ast.ly:283
class Expr {
  inferred_type_args: [TypeExpr]
  kind: ExprKind
  resolved_type: TypeExpr?
  span: Span
}

// ast.ly:91
class Field {
  default_value: Expr?
  guarded_by: Sym?
  is_public: bool
  name: Sym?
  span: Span
  type_expr: TypeExpr?
}

// ast.ly:377
class File {
  filename: string
  span: Span
}

// ast.ly:77
class FuncDecl {
  body: Block?
  is_public: bool
  name: Sym?
  receiver_type: Sym?
  return_type: TypeExpr?
  span: Span
}

// ast.ly:183
class ImplBlock {
  for_type: Sym?
  interface_name: Sym?
  label: Sym?
  span: Span
}

// ast.ly:173
class ImplMapping {
  inline_func: FuncDecl?
  kind: ImplMappingKind
  method_name: Sym?
  span: Span
  target_class: Sym?
  target_member: Sym?
  type_param: Sym?
}

// ast.ly:213
class ImportDecl {
  alias: Sym?
  path: string
  span: Span
}

// ast.ly:157
class InterfaceDecl {
  implements: [Sym]
  is_public: bool
  name: Sym?
  span: Span
}

// ast.ly:145
class InterfaceEmbed {
  name: Sym?
  span: Span
}

// ast.ly:138
class InterfaceFieldDecl {
  name: Sym?
  span: Span
  type_expr: TypeExpr?
  type_param: Sym?
}

// ast.ly:362
class LyricBlock {
  name: Sym?
  span: Span
}

// ast.ly:305
class MatchArm {
  body: Block?
  guard: Expr?
  pattern: Pattern?
  patterns: [Pattern]
  span: Span
}

// ast.ly:69
class Param {
  is_mut: bool
  is_self: bool
  name: Sym?
  span: Span
  type_expr: TypeExpr?
}

// ast.ly:300
class Pattern {
  kind: PatternKind
  span: Span
}

// ast.ly:15
struct Pos {
  column: i32
  file: Sym?
  line: i32
}

// ast.ly:202
class RelationDecl {
  child: RelationSide
  hint: Sym?
  is_many: bool
  kind: RelationKind
  parent: RelationSide
  span: Span
}

// ast.ly:196
struct RelationSide {
  label: Sym?
  type_args: [Sym]
  type_name: Sym?
}

// ast.ly:347
class SelectCase {
  bind_var: Sym?
  body: Block?
  expr: Expr?
  is_default: bool
  span: Span
}

// ast.ly:21
struct Span {
  end: Pos
  start: Pos
}

// ast.ly:336
class Stmt {
  kind: StmtKind
  span: Span
}

// ast.ly:114
class StructDecl {
  is_public: bool
  name: Sym?
  span: Span
}

// ast.ly:250
struct StructLitField {
  name: Sym?
  value: Expr?
}

// ast.ly:47
class TupleField {
  name: Sym?
  type_expr: TypeExpr?
}

// ast.ly:219
class TypeAliasDecl {
  is_public: bool
  name: Sym?
  span: Span
  type_expr: TypeExpr?
}

// ast.ly:42
class TypeExpr {
  kind: TypeExprKind
  span: Span
}

// ast.ly:54
class TypeParam {
  constraint: Sym?
  name: Sym?
  span: Span
}

// ast.ly:60
class WhereClause {
  constraint: Sym?
  span: Span
  variable: Sym?
}

