    method scan(self) -> Token
      source: lexer.ly:458
      why: "The main lexing loop: skips whitespace and comments, then dispatches on the next byte to the appropriate scan_* helper, producing exactly one Token per call. Honors bracket_depth to suppress newlines inside () and []. This is the single entry point feeding peek and next."

  func new_lexer(src_text: string, filename: Sym) -> Lexer
