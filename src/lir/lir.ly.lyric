      doc: "Populated by resolve_class_types() for LTyClassHandle; nil until that pass runs."
    field elem: LType?
    field fields: [LField]
    field is_exported: bool
    field is_owned: bool
    field is_permanent: bool
    field key: LType?
    field kind: LTypeKind
      doc: "Discriminator selecting which LTypeKind variant this LType represents. Other fields are interpreted per kind (elem for slice/optional, key+elem for map, fields for struct/tuple, variants for tagged union, params+ret for func, etc.)."
    field name: string
    field params: [LType?]
    field ret: LType?
    field type_args: [LType?]
    field variants: [LVariant]

