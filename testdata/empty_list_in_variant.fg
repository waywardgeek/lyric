// empty_list_in_variant.fg — test empty list literals in enum variant constructors
// Exercises the case where [] appears as an argument to an enum variant
// constructor inside a positional struct literal. The checker must not
// reject Sequence(Unit) for empty lists in known-type positions.

forge empty_list_in_variant {

  enum Shape {
    Circle(radius: f32)
    Polygon(sides: [i32])
    Tagged(name: string, values: [i32])
  }

  struct Container {
    shape: Shape
    label: string
  }

  func test_empty_list_in_variant() {
    // Empty list as variant arg
    let s: Shape = Polygon([])
    match s {
      Polygon(sides) => {
        println(len(sides))
      }
      _ => { println("wrong") }
    }
  }

  func test_empty_list_in_struct() {
    // Empty list inside variant inside struct literal
    let c = Container { shape: Polygon([]), label: "empty" }
    println(c.label)
  }

  func test_nonempty_for_comparison() {
    let s: Shape = Polygon([3, 4, 5])
    match s {
      Polygon(sides) => {
        println(len(sides))
        println(sides[0])
      }
      _ => { println("wrong") }
    }
  }

  func test_tagged_empty() {
    let s: Shape = Tagged("test", [])
    match s {
      Tagged(name, values) => {
        println(name)
        println(len(values))
      }
      _ => { println("wrong") }
    }
  }

  func main() {
    test_empty_list_in_variant()
    test_empty_list_in_struct()
    test_nonempty_for_comparison()
    test_tagged_empty()
  }
}
