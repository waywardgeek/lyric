grok calculator {

  // Token types
  enum TokenKind {
    Number
    Plus
    Minus
    Star
    Slash
    LParen
    RParen
    EOF
  }

  // A token with its kind and optional numeric value
  struct Token {
    kind: TokenKind
    value: f64
  }

  // Tokenizer: breaks input string into tokens
  func tokenize(input: string) -> [Token] {
    let mut tokens: [Token] = []
    return tokens
  }

  // Recursive descent parser/evaluator
  func eval_simple(a: f64, op: string, b: f64) -> f64 {
    if op == "+" {
      return a + b
    }
    if op == "-" {
      return a - b
    }
    if op == "*" {
      return a * b
    }
    if op == "/" {
      return a / b
    }
    return 0.0
  }

  // Stack-based expression evaluator
  class ExprEval() {
    values: [f64]
    ops: [string]

    func push_value(mut self, v: f64) {
      self.values.push(v)
    }

    func push_op(mut self, op: string) {
      self.ops.push(op)
    }

    func pop_value(mut self) -> f64? {
      if self.values.len() == 0 {
        return nil
      }
      let idx = self.values.len() - 1
      let v = self.values[idx]
      self.values = self.values[:idx]
      return v
    }

    func pop_op(mut self) -> string? {
      if self.ops.len() == 0 {
        return nil
      }
      let idx = self.ops.len() - 1
      let op = self.ops[idx]
      self.ops = self.ops[:idx]
      return op
    }

    func apply_top(mut self) -> bool {
      let op = self.pop_op()
      if isnull(op) {
        return false
      }
      let b = self.pop_value()
      let a = self.pop_value()
      if isnull(a) || isnull(b) {
        return false
      }
      let result = eval_simple(a!, op!, b!)
      self.push_value(result)
      return true
    }

    func result(self) -> f64? {
      if self.values.len() == 0 {
        return nil
      }
      return self.values[0]
    }
  }

  func main() {
    // Test simple evaluation
    let plus = "+"
    let minus = "-"
    let star = "*"
    let slash = "/"
    println(f"2 + 3 = {eval_simple(2.0, plus, 3.0)}")
    println(f"10 - 4 = {eval_simple(10.0, minus, 4.0)}")
    println(f"6 * 7 = {eval_simple(6.0, star, 7.0)}")
    println(f"15 / 3 = {eval_simple(15.0, slash, 3.0)}")

    // Test stack-based evaluator: compute 3 + 4 * 2
    let mut ev = ExprEval()
    ev.push_value(3.0)
    ev.push_op(plus)
    ev.push_value(4.0)
    ev.push_op(star)
    ev.push_value(2.0)

    // Apply * first (higher precedence)
    ev.apply_top()
    // Apply +
    ev.apply_top()

    let r = ev.result()
    if !isnull(r) {
      println(f"3 + 4 * 2 = {r!}")
    }

    // Test: (5 + 3) * 2
    let mut ev2 = ExprEval()
    ev2.push_value(5.0)
    ev2.push_op(plus)
    ev2.push_value(3.0)
    ev2.apply_top()
    ev2.push_op(star)
    ev2.push_value(2.0)
    ev2.apply_top()

    let r2 = ev2.result()
    if !isnull(r2) {
      println(f"(5 + 3) * 2 = {r2!}")
    }

    println("calculator done")
  }
}
