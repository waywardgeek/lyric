forge sym_test {

  func main() {
    let s1 = sym("hello")
    let s2 = sym("world")
    let s3 = sym("hello")

    println(s1.get_name())
    println(s2.get_name())

    // Same string should produce same hash
    if s1.get_hash() == s3.get_hash() {
      println("hashes match")
    }

    // Different strings should (almost certainly) produce different hashes
    if s1.get_hash() != s2.get_hash() {
      println("hashes differ")
    }

    // Direct hash_string call
    let h = hash_string("test")
    if h != <u64>0 {
      println("hash is nonzero")
    }
  }

}
