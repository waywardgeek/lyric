// positional_struct_lit.fg — test positional struct literal parsing
// Tests that struct literals with positional (unnamed) fields work
// inside parenthesized expressions and argument lists (expr_depth > 0)

forge positional_struct_lit {
  struct Point {
    x: i32
    y: i32
  }

  struct Pair {
    a: string
    b: i32
  }

  func make_pair(p: Pair) -> Pair {
    return p
  }

  func test_positional_in_tuple() {
    // Positional struct literal inside a tuple
    let tup = (Point { 10, 20 }, 42)
    println(tup._0.x)
    println(tup._0.y)
    println(tup._1)
  }

  func test_positional_in_args() {
    // Positional struct literal as function argument
    let p = make_pair(Pair { "hello", 99 })
    println(p.a)
    println(p.b)
  }

  func test_positional_in_list() {
    // Positional struct literal inside list literal
    let pts: [Point] = [Point { 1, 2 }, Point { 3, 4 }]
    println(pts[0].x)
    println(pts[1].y)
  }

  func test_named_still_works() {
    // Named fields should still work everywhere
    let p = Point { x: 5, y: 6 }
    println(p.x)
    println(p.y)
  }

  func main() {
    test_positional_in_tuple()
    test_positional_in_args()
    test_positional_in_list()
    test_named_still_works()
  }
}
