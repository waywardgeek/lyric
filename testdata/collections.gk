grok collections {
  import fmt from "fmt"

  // Generic stack class
  class Stack<T>() {
    items: [T]

    func push(mut self, item: T) {
      self.items = append(self.items, item)
    }

    func pop(mut self) -> T? {
      if len(self.items) == 0 {
        return nil
      }
      let last = self.items[len(self.items) - 1]
      // TODO: slice syntax not yet supported
      return last
    }

    func size(self) -> i32 {
      return len(self.items)
    }

    func peek(self) -> T? {
      if len(self.items) == 0 {
        return nil
      }
      return self.items[len(self.items) - 1]
    }
  }

  // Generic pair struct
  struct Pair<A, B> {
    first: A
    second: B
  }

  // Higher-order function with generics
  func transform<T, U>(xs: [T], f: (T) -> U) -> [U] {
    let mut result: [U] = []
    for x in xs {
      result = append(result, f(x))
    }
    return result
  }

  func double(x: i32) -> i32 {
    return x * 2
  }

  func to_string(x: i32) -> string {
    return f"{x}"
  }

  func main() {
    // Test generic stack
    let mut s = Stack<i32>()
    s.push(10)
    s.push(20)
    s.push(30)
    println(f"size: {s.size()}")
    let top = s.peek()
    if !isnull(top) {
      println(f"peek: {top!}")
    }
    let popped = s.pop()
    if !isnull(popped) {
      println(f"popped: {popped!}")
    }
    println(f"size after pop: {s.size()}")

    // Test generic higher-order function
    let nums = [1, 2, 3, 4, 5]
    let doubled = transform<i32, i32>(nums, double)
    println(f"doubled: {doubled}")

    let strs = transform<i32, string>(nums, to_string)
    println(f"strings: {strs}")

    // Test with lambda
    let tripled = transform<i32, i32>(nums, |x: i32| -> i32 { x * 3 })
    println(f"tripled: {tripled}")

    println("collections done")
  }
}
