forge short_circuit {
  func get_first(items: [string]) -> string {
    if len(items) > 0 && items[0] == "hello" {
      return "found hello"
    }
    return "not found"
  }

  func or_short(a: i32) -> string {
    if a == 0 || 10 / a > 2 {
      return "true"
    }
    return "false"
  }

  func test_and_empty_slice() {
    let result = get_first([])
    assert_eq(result, "not found", "empty slice should not crash")
  }

  func test_and_match() {
    let result = get_first(["hello"])
    assert_eq(result, "found hello", "should find hello")
  }

  func test_and_no_match() {
    let result = get_first(["world"])
    assert_eq(result, "not found", "should not find hello")
  }

  func test_or_zero() {
    let result = or_short(0)
    assert_eq(result, "true", "zero should short-circuit before division")
  }

  func test_or_large() {
    let result = or_short(1)
    assert_eq(result, "true", "10/1 > 2 is true")
  }

  func test_or_false() {
    let result = or_short(5)
    assert_eq(result, "false", "5!=0 and 10/5=2 not > 2")
  }

}
