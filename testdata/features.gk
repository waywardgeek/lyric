grok features {
    // Test numeric widening: i32 + i64 should emit Go cast
    func Widen(x: i32) -> i64 {
        let y: i64 = 100
        return x + y
    }

    // Test break/continue in loops
    func SumUntil(limit: i32) -> i32 {
        let mut sum: i32 = 0
        let mut i: i32 = 0
        while true {
            if i >= limit {
                break
            }
            if i == 3 {
                i = i + 1
                continue
            }
            sum = sum + i
            i = i + 1
        }
        return sum
    }

    // Test match statement
    func Classify(x: i32) -> i32 {
        match x {
            0 => { return 0 }
            1 => { return 1 }
            _ => { return 2 }
        }
        return 2
    }

    // Test struct + method-like function
    struct Vec2 {
        X: f64
        Y: f64
    }

    func Dot(a: Vec2, b: Vec2) -> f64 {
        return a.X * b.X + a.Y * b.Y
    }

    // Test for loop with list
    func SumList(xs: [i32]) -> i32 {
        let mut total: i32 = 0
        for x in xs {
            total = total + x
        }
        return total
    }

    func Main() {
        let _ = Widen(42)
        let _ = SumUntil(10)
        let _ = Classify(5)
        let a = Vec2{X: 1.0, Y: 2.0}
        let b = Vec2{X: 3.0, Y: 4.0}
        let _ = Dot(a, b)

        // Test typed list/map literals
        let nums = [1, 2, 3]
        let _ = SumList(nums)
        let scores = map[string]i32{"alice": 100, "bob": 95}
        let _ = scores
    }
}
