// Test for HashedList stdlib interface
forge hashed_list {

  class Registry() {}

  class Entry(key: u64, value: i32) {
    pub func hash_key(self) -> u64 {
      return self.key
    }
  }

  relation HashedList Registry:reg owns [Entry:entry]

  impl HashedList<Registry, Entry> {
    P.children <-> Registry.reg_children
    P.buckets <-> Registry.reg_buckets
    P.hash_cap <-> Registry.reg_hash_cap
    P.hash_count <-> Registry.reg_hash_count
    C.parent <-> Entry.entry_parent
    C.index <-> Entry.entry_index
  }

  func main() {
    let reg = Registry()

    // Insert entries
    let e1 = Entry(<u64>100, 10)
    hash_insert<Registry, Entry>(reg, e1)
    let e2 = Entry(<u64>200, 20)
    hash_insert<Registry, Entry>(reg, e2)
    let e3 = Entry(<u64>300, 30)
    hash_insert<Registry, Entry>(reg, e3)

    // Lookup
    let found = hash_lookup<Registry, Entry>(reg, <u64>200)
    if !isnull(found) {
      println(f"found 200: {found!.value}")
    }

    let missing = hash_lookup<Registry, Entry>(reg, <u64>999)
    if isnull(missing) {
      println("999 not found")
    }

    // Count
    println(f"count: {reg.reg_hash_count}")

    // Remove
    let removed = hash_remove<Registry, Entry>(reg, <u64>100)
    println(f"removed 100: {removed}")
    println(f"count after remove: {reg.reg_hash_count}")

    // Verify 200 still there
    let e200 = hash_lookup<Registry, Entry>(reg, <u64>200)
    if !isnull(e200) {
      println(f"200 still there: {e200!.value}")
    }

    // Verify 100 gone
    let e100 = hash_lookup<Registry, Entry>(reg, <u64>100)
    if isnull(e100) {
      println("100 gone")
    }

    // Replace existing key
    let e4 = Entry(<u64>200, 99)
    hash_insert<Registry, Entry>(reg, e4)
    let e200b = hash_lookup<Registry, Entry>(reg, <u64>200)
    if !isnull(e200b) {
      println(f"200 replaced: {e200b!.value}")
    }
    println(f"count after replace: {reg.reg_hash_count}")

    println("done")
  }
}
