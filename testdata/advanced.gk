grok advanced {
    // Enum with variants
    enum Shape {
        Circle(radius: f64)
        Rectangle(width: f64, height: f64)
        Empty
    }

    // Class with constructor params and methods
    class Counter(count: i32) {
        func Increment(mut self) {
            self.count = self.count + 1
        }

        func Get(self) -> i32 {
            return self.count
        }
    }

    // Function using match-as-expression
    func Describe(x: i32) -> i32 {
        let result = match x {
            0 => { 10 }
            1 => { 20 }
            _ => { 30 }
        }
        return result
    }

    // Nested if/else
    func Abs(x: i32) -> i32 {
        if x < 0 {
            return 0 - x
        } else {
            return x
        }
    }

    // Typed list and map literals
    func SumList(xs: [i32]) -> i32 {
        let mut total: i32 = 0
        for x in xs {
            total = total + x
        }
        return total
    }

    // Higher-order function with function type param
    func Apply(f: (i32) -> i32, x: i32) -> i32 {
        return f(x)
    }

    // Multi-param function type
    func ApplyBinOp(f: (i32, i32) -> i32, a: i32, b: i32) -> i32 {
        return f(a, b)
    }

    // Function that matches on enum variants
    func Area(s: Shape) -> f64 {
        return match s {
            Circle(r) => { 3.14159 * r * r }
            Rectangle(w, h) => { w * h }
            Empty => { 0.0 }
        }
    }

    func Main() {
        // Enum variant constructors
        let c = Circle(5.0)
        let r = Rectangle(3.0, 4.0)
        let e = Empty
        let _ = Area(c)
        let _ = Area(r)
        let _ = Area(e)

        // Class usage
        let mut ctr = Counter{Count: 0}
        ctr.Increment()
        let _ = ctr.Get()

        // Match-as-expression
        let _ = Describe(1)

        // Abs
        let _ = Abs(-5)

        // Typed collection literals
        let nums = [1, 2, 3]
        let _ = SumList(nums)
        let scores = map[string]i32{"alice": 100, "bob": 95}
        let _ = scores

        // Lambda / function type usage
        let _ = Apply(Abs, 42)
        let double = |x: i32| -> i32 { x * 2 }
        let _ = Apply(double, 5)
        let add = |a: i32, b: i32| -> i32 { a + b }
        let _ = ApplyBinOp(add, 3, 4)
    }
}
