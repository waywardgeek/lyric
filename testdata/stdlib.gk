// stdlib.gk — tests Go stdlib import and usage, including type casts
grok stdlib_test {
  import fmt from "fmt"
  import strings from "strings"
  import strconv from "strconv"

  func main() {
    // String operations
    let greeting = strings.ToUpper("hello, grok!")
    fmt.Println(greeting)

    // String conversion — strconv.Itoa expects Go's int, so cast from i32
    let num = 42
    let s = strconv.Itoa(<int>num)
    fmt.Println("The answer is " + s)

    // Numeric casts between Grok types
    let x: i32 = 100
    let y: i64 = <i64>x
    let z: i32 = <i32>y
    fmt.Println(f"x={x}, y={y}, z={z}")
  }
}
