grok hello {
    func Factorial(n: i32) -> i32 {
        if n <= 1 {
            return 1
        }
        return n * Factorial(n - 1)
    }

    struct Point {
        X: f64
        Y: f64
    }

    func Abs(p: Point) -> f64 {
        return p.X * p.X + p.Y * p.Y
    }

    func Main() {
        let _ = Factorial(5)
        let p = Point{X: 3.0, Y: 4.0}
        let _ = Abs(p)
        let mut i: i32 = 0
        while i < 10 {
            i = i + 1
        }
    }
}
