// embed.fg — interface embedding test

forge embed_test {

  interface Base<P, C> {
    field P.first: C?
    field C.parent: P?
  }

  interface Extended<P, C> {
    embed Base<P, C>

    field P.count: i32
  }

  class Team(name: string) {}
  class Player(name: string) {}

  relation Extended Team:team owns [Player:player]

  impl Extended<Team, Player> {
    P.count <-> Team.team_count
  }

  func main() {
    let t = Team("Warriors")
    println(f"count: {t.team_count}")
  }
}
